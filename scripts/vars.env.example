# vars.env.example — Variables de déploiement FIDUCIS
# Copier ce fichier en vars.env et adapter les valeurs avant lancement
# IMPORTANT : ne jamais committer vars.env dans Git (contient des secrets)

# Nœud Proxmox (nom affiché dans l'interface)
PROXMOX_NODE=pve

# Pool de stockage Proxmox
STORAGE_POOL=local-lvm

# Bridge réseau principal (VLAN-aware)
BRIDGE=vmbr0

# Stockage des ISOs
ISO_STORAGE=local

# Mot de passe cloud-init des VMs (à changer obligatoirement)
VM_PASSWORD=ChangeMe123!

# Rétention snapshots VMs critiques (Sage, File) — jours
SNAPSHOT_RETENTION_DAYS=14

# Rétention snapshots VMs secondaires — jours
SNAPSHOT_RETENTION_WEEKLY=28
